# =============================================================================
# SchulFit - Docker Ignore
# =============================================================================

# Git
.git
.gitignore

# Dependencies (use container's node_modules)
node_modules

# Build output
dist

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/

# Claude Code
.claude/

# Documentation (not needed in image)
*.md
LICENSE
screenshots/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
